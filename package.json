{
  "name": "movie-dashbord",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:e2e": "PLAYWRIGHT_E2E=1 nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && playwright install chromium webkit",
    "playwright:install": "playwright install chromium webkit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage && open coverage/vitest/index.html",
    "test:e2e": "playwright test",
    "test:e2e:clean": "rm -rf test-results",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report coverage/e2e",
    "test:all": "npm run test && npm run test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@phosphor-icons/vue": "^2.2.1",
    "clsx": "^2.1.1",
    "nuxt": "^4.4.2",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/eslint": "^1.15.2",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwind-scrollbar": "^3.1.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
